# .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control — it contains secrets.
# .env is already in .gitignore (add it if not).

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ach_user
POSTGRES_PASSWORD=ach_secret
POSTGRES_DB=ach_orchestrator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# Assembled DSN used by pgxpool.New(). You can construct this from the
# individual variables above, or set it directly.
DATABASE_URL=postgres://ach_user:ach_secret@localhost:5432/ach_orchestrator?sslmode=disable

# ── Application ───────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── Phase 2 (Temporal) — not used yet ────────────────────────────────────────
# TEMPORAL_HOST_PORT=localhost:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=ach-payment-queue

# ── Phase 2 (Redis) — not used yet ───────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
